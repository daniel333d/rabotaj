# Supabase project settings — find these in your Supabase project at
# Project Settings > API (https://supabase.com/dashboard/project/_/settings/api)

# Public — safe to expose in the browser bundle.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SECRET — server-only. Bypasses Row Level Security entirely. Never prefix
# this with NEXT_PUBLIC_, never import it from a Client Component, and never
# commit a real value. Only used in app/admin/** server actions via
# lib/supabase/admin.ts.
SUPABASE_SERVICE_ROLE_KEY=
